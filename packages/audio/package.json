{
	"name": "@outpacelabs/audio",
	"version": "0.2.1",
	"description": "Interface sounds with a sense of direction. Tiny procedural UI sounds, synthesized from pure data specs, no audio files.",
	"keywords": [
		"audio",
		"ui-sound",
		"sound-design",
		"web-audio",
		"sound-effects",
		"procedural-audio",
		"haptics"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/outpacelabs/audio.git",
		"directory": "packages/audio"
	},
	"author": "Outpace Studios (https://outpacestudios.com)",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"import": "./dist/react.js",
			"require": "./dist/react.cjs"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "pnpm build && node test/properties.mjs",
		"prepublishOnly": "pnpm test",
		"prepare": "tsup"
	},
	"peerDependencies": {
		"react": ">=18"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/react": "^19.2.10",
		"react": "^19.2.4",
		"tsup": "^8.3.5",
		"typescript": "^5.9.3"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
